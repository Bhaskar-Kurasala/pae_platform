# ═══════════════════════════════════════════
# Production AI Engineering Platform — .env
# Copy to .env and fill in real values
# NEVER commit .env to git
# ═══════════════════════════════════════════

# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/platform
POSTGRES_DB=platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Authentication ──
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── OAuth (GitHub) ──
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/callback/github

# ── OAuth (Google) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/callback/google

# ── AI / LLM ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Pinecone (Vector Store) ──
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=platform-knowledge

# ── Stripe (Payments) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SELF_PACED=
STRIPE_PRICE_COHORT=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# ── GitHub (Repo Management) ──
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_PUBLIC_REPO=production-rag-engineering
GITHUB_PRIVATE_REPO=production-rag-engineering-complete

# ── SendGrid (Email) ──
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@pae.dev

# ── Discord ──
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_PAID_ROLE_ID=

# ── Meilisearch ──
MEILI_MASTER_KEY=masterKey123
MEILI_URL=http://localhost:7700

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
