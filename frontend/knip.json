{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/app/**/page.tsx",
    "src/app/**/layout.tsx",
    "src/app/**/loading.tsx",
    "src/app/**/error.tsx",
    "src/app/**/not-found.tsx",
    "src/app/**/route.{ts,tsx}",
    "src/middleware.ts",
    "next.config.{js,ts,mjs}",
    "vitest.config.ts",
    "playwright.config.ts",
    "e2e/**/*.spec.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/**/*.test.{ts,tsx}",
    "src/test/**",
    "src/**/__tests__/**",
    "src/**/__stories__/**",
    "src/**/*.stories.{ts,tsx}"
  ],
  "ignoreDependencies": [
    "@types/.*",
    "eslint-.*",
    "prettier",
    "vitest",
    "@vitest/.*",
    "@testing-library/.*",
    "@playwright/test"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "warn",
    "exports": "warn",
    "types": "warn",
    "duplicates": "warn",
    "unlisted": "off",
    "binaries": "off"
  }
}
